{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "demo-e-commerce",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "main": ".open-next/worker/index.mjs",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
}
